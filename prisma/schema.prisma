generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  categoryId    String         @id @default(uuid())
  categoryName  String
  description   String
  status        CategoryStatus @default(active)
  userId        String
  icon          String
  priority      PriorityStatus @default(normal)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  shoppingItems ShoppingItem[]
}

model ShoppingItem {
  itemId      String         @id @default(uuid())
  itemName    String
  description String
  status      ItemStatus     @default(active)
  categoryId  String
  priority    PriorityStatus @default(normal)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  quantity    Int
  unit        UnitStatus     @default(kg)
  category    Category       @relation(fields: [categoryId], references: [categoryId])
}

model User {
  userId    String   @id @default(uuid())
  fullName  String
  userName  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiSuggestion {
  id         String       @id @default(uuid())
  userId     String
  prompt     String
  createdAt  DateTime     @default(now())
  categories AICategory[]
}

model AICategory {
  id           String         @id @default(uuid())
  suggestionId String
  categoryName String
  priority     PriorityStatus @default(normal)
  AiSuggestion AiSuggestion   @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  items        AIItem[]
}

model AIItem {
  id         String          @id @default(uuid())
  categoryId String
  itemName   String
  quantity   Float?
  unit       UnitStatus?
  priority   PriorityStatus?
  AICategory AICategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

enum CategoryStatus {
  active
  completed
}

enum ItemStatus {
  active
  archived
}

enum PriorityStatus {
  normal
  low
  medium
  high
}

enum UnitStatus {
  kg
  piece
  pack
  dozen
  box
  g
  l
  ml
  bottle
  can
  cup
  other
}
